<script is:inline>
  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target;
    const nombre = form.querySelector('#nombre')?.value || '';
    const telefono = form.querySelector('#telefono')?.value || '';
    const evento = form.querySelector('#evento')?.value || '';
    const mensaje = form.querySelector('#mensaje')?.value || '';
    const text = `Hola LUMINAPRO, soy ${nombre}. Tel: ${telefono}. Evento: ${evento}. ${mensaje}`;
    window.open(`https://wa.me/5527221736?text=${encodeURIComponent(text)}`, '_blank');
  });
</script>
